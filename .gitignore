# =============================================================================
# OpenSmith self-improvement runtime artifacts
# These are generated when using OpenSmith to develop OpenSmith itself.
# They should NOT be included in the distributed plugin.
# =============================================================================

# Claude Code runtime directory (created by setup.sh / self-improvement)
.claude/

# CLAUDE.md generated by setup.sh for self-improvement sessions
CLAUDE.md

# Memory bank (semantic search DB, embeddings)
*.db
*.sqlite
*.sqlite3
memory-bank/

# Bug tracker runtime
bugs.json

# Phase state tracking (session-specific, runtime only)
.opensmith/states/

# Session / metrics logs
*.log
logs/

# =============================================================================
# General development artifacts
# =============================================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment / secrets
.env
.env.*
credentials.json

# Node (if any)
node_modules/
